import os

# Get current directory files
files = os.listdir()

print("Files in current directory:")
for f in files:
    print(f)

# Count .py files
py_files = [f for f in files if f.endswith(".py")]

print("\nTotal .py files:", len(py_files))

# Display content of one .py file
if py_files:
    print("\nContent of:", py_files[0])
    with open(py_files[0], "r") as file:
        print(file.read())

